generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?
  emailVerified DateTime?
  image         String?
  role          String    @default("USER") // "USER" or "ADMIN"

  // Profile fields
  phone   String?
  address String?
  city    String?
  country String?

  // Relations
  bookings  Booking[]
  blogPosts BlogPost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlogPost {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  excerpt       String?
  content       String   @db.Text
  featuredImage String?
  category      String   @default("travel")
  tags          String[]
  published     Boolean  @default(false)
  authorId      String
  author        User     @relation(fields: [authorId], references: [id])
  
  // SEO Fields
  seoTitle      String?  // New field for Meta Title
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Booking {
  id         String  @id @default(cuid())
  pickup     String
  dropoff    String
  date       String
  time       String
  passengers Int
  tripType   String
  returnDate String?
  returnTime String?
  status     String  @default("pending") // pending, confirmed, completed, cancelled

  // Guest details (snapshot)
  customerName  String?
  customerEmail String?
  customerPhone String?

  // Relation to User (optional, for registered users)
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SEOSettings {
  id          String   @id @default(cuid())
  pagePath    String   @unique
  title       String
  description String
  keywords    String[]
  ogImage     String?
  page        Page?    @relation(fields: [pageId], references: [id])
  pageId      String?  @unique
  updatedAt   DateTime @updatedAt
}

model SmtpSettings {
  id        String   @id @default(cuid())
  host      String
  port      Int
  user      String
  password  String
  fromEmail String
  secure    Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

model Page {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  content     String        @db.Text
  description String?
  keywords    String[]
  ogImage     String?
  published   Boolean       @default(false)
  template    String        @default("default") // default, blog, landing, etc.
  
  // SEO Fields
  seoTitle      String?  // New field for Meta Title
  
  // Featured Image
  featuredImage String?
  imagePosition String   @default("center") // top, center, bottom

  sections    PageSection[]
  seoSettings SEOSettings?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model PageSection {
  id        String   @id @default(cuid())
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  name      String
  content   String   @db.Text
  order     Int      @default(0)
  type      String   @default("text") // text, image, gallery, form, etc.
  settings  Json? // JSON for section-specific settings
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSettings {
  id              String   @id @default(cuid())
  brandName       String   @default("Lugvia Movers")
  primaryPhone    String?
  whatsappNumber  String   @default("+16467197124")
  supportEmail    String?
  addressLine     String?
  defaultOgImage  String?
  // SEO / Verification
  googleSiteVerification String?
  googleAnalyticsId      String?
  googleTagManagerId     String?

  // Social links
  facebookUrl   String?
  instagramUrl  String?
  twitterUrl    String?
  youtubeUrl    String?
  updatedAt       DateTime @updatedAt
}

model MovingCity {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  state         String?
  country       String   @default("USA")
  heroImage     String?
  content       String   @db.Text
  published     Boolean  @default(false)

  // SEO
  seoTitle      String?
  description   String?
  keywords      String[]
  ogImage       String?

  // Optional structured FAQ JSON: [{question, answer}]
  faqs          Json?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model MovingService {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  shortIntro    String?
  heroImage     String?
  content       String   @db.Text
  published     Boolean  @default(false)

  // SEO
  seoTitle      String?
  description   String?
  keywords      String[]
  ogImage       String?
  faqs          Json?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model MovingLead {
  id             String   @id @default(cuid())
  originCity     String?
  originState    String?
  destinationCity String?
  destinationState String?
  moveDate       DateTime?
  propertySize   String?
  services       String[] // packing, storage, etc.
  notes          String?

  fullName       String
  phone          String
  email          String?
  preferredContact String? // phone, whatsapp, email

  status         String   @default("new") // new, contacted, booked, lost
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model DriverRegistration {
  id              String   @id @default(cuid())
  fullName        String
  phone           String
  email           String?
  licenseType     String
  yearsExperience Int?
  primaryCity     String?
  notes           String?
  status          String   @default("new") // new, reviewed, approved, rejected
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, createdAt])
}

model VehicleRegistration {
  id             String   @id @default(cuid())
  ownerName      String
  phone          String
  email          String?
  vehicleType    String
  plateNumber    String
  capacity       String?
  serviceCoverage String?
  notes          String?
  status         String   @default("new") // new, reviewed, approved, rejected
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status, createdAt])
}

model MovingRateCard {
  id            String   @id @default(cuid())
  name          String
  active        Boolean  @default(true)

  // Scope
  serviceSlug   String?  // null = applies to any service
  originState   String?  // null = any
  originCity    String?  // null = any

  // Base pricing
  currency      String   @default("USD")
  minimumPrice  Int      @default(0) // cents
  basePrice     Int      @default(0) // cents
  perMile       Int      @default(0) // cents per mile (optional)

  // Labor time approximation (per move size) in hours
  hoursStudio   Decimal  @default(2.5)
  hours1br      Decimal  @default(3.5)
  hours2br      Decimal  @default(5.0)
  hours3br      Decimal  @default(7.0)
  hours4brPlus  Decimal  @default(9.0)

  // Labor price
  perHour       Int      @default(0) // cents per hour

  // Multipliers / add-ons
  packingFullMultiplier     Decimal @default(1.35)
  packingPartialMultiplier  Decimal @default(1.20)
  storageFlat              Int     @default(0) // cents
  junkRemovalFlat          Int     @default(0) // cents
  assemblyFlat             Int     @default(0) // cents

  // Margin / resell
  resellerMarkupPercent Int @default(20) // % added on top

  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  @@index([active, serviceSlug])
  @@index([originState, originCity])
}

model MediaGallery {
  id          String   @id @default(cuid())
  title       String
  alt         String
  url         String
  category    String   @default("general") // service, city, blog, hero, general
  tags        String[]
  width       Int?
  height      Int?
  fileSize    Int?     // bytes
  mimeType    String?
  uploadedBy  String?  // user ID or "system"
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([tags])
}
